# Shared public Supabase values
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin server only. Never expose this to mobile or browser bundles.
SUPABASE_SERVICE_ROLE_KEY=replace-in-hosting-secret-store

# App identity
EXPO_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Optional local test values
TEST_PLAYER_EMAIL=player@example.test
TEST_ADMIN_EMAIL=admin@example.test
